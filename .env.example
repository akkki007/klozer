# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://leadmax:leadmax_dev_password@localhost:5433/leadmax
# Sync URL used only by Alembic (migration runner)
DATABASE_SYNC_URL=postgresql://leadmax:leadmax_dev_password@localhost:5433/leadmax

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (FastAPI issues tokens; NextAuth stores them in session) ─────────────
JWT_SECRET=change-me-min-32-chars-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# ─── Token encryption (AES-Fernet for OAuth tokens at rest) ──────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENC_KEY=

# ─── Meta (Facebook + Instagram + WhatsApp share one Business app) ────────────
FB_APP_ID=
FB_APP_SECRET=
META_GRAPH_VERSION=v25.0
META_WEBHOOK_VERIFY_TOKEN=        # A string you invent — must match what you set in Meta dashboard
WHATSAPP_CONFIGURATION_ID=        # From Embedded Signup config in Meta for Developers
# Facebook Login for Business — paste the Configuration ID from the dashboard.
# When set, the requested permissions come FROM this configuration and FB_SCOPES
# below is ignored (do NOT also send scope, or Meta returns "Invalid Scopes").
FB_LOGIN_CONFIG_ID=

# OAuth scopes — used ONLY by the classic Facebook Login flow (i.e. when
# FB_LOGIN_CONFIG_ID is blank). Leave blank to request the full marketing set.
# Classic-flow dev starter set:
#   FB_SCOPES=public_profile,pages_show_list,pages_read_engagement,pages_read_user_content
FB_SCOPES=

# ─── LinkedIn (scaffold only in P1 — awaiting partner approval) ──────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202602       # YYYYMM — bump when LinkedIn deprecates

# ─── OAuth redirect base (FastAPI handles server-side OAuth) ─────────────────
OAUTH_REDIRECT_BASE=http://localhost:8000/api/integrations

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
