# ─── Web (Next.js / NextAuth) ────────────────────────────────────────────────
# Copy to apps/web/.env.local and fill in.

# FastAPI backend the web app talks to (server-side: NextAuth, server components)
API_BASE_URL=http://localhost:8000
# Same URL exposed to the browser (client-side api-client)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth v5 — required. Generate: openssl rand -base64 32
AUTH_SECRET=change-me-random-base64-string
# Needed when running behind a proxy / non-localhost host
AUTH_TRUST_HOST=true

# Facebook login (NextAuth FacebookProvider) — your Meta app credentials
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=
